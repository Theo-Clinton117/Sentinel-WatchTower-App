{
  "expo": {
    "name": "Sentinel-Watchtower",
    "slug": "sentinel-watchtower",
    "scheme": "sentinel",
    "version": "0.1.0",
    "entryPoint": "index",
    "orientation": "portrait",
    "icon": "./assets/icons/android-icon.png",
    "splash": {
      "backgroundColor": "#07101F"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "icon": "./assets/icons/ios-icon-liquid-glass.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Sentinel to access your location for emergency tracking.",
          "locationAlwaysPermission": "Allow Sentinel to access your location in the background for emergency tracking."
        }
      ],
      "expo-secure-store"
    ],
    "android": {
      "package": "com.sentinel.watchtower",
      "icon": "./assets/icons/android-icon.png"
    }
  }
}
